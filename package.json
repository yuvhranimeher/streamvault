{
  "name": "streamvault",
  "version": "1.0.0",
  "type": "commonjs",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "details:shadow:audit": "node tools/details-parity-v1/audit-details-fixtures.js",
    "details:shadow:schema": "node tools/details-parity-v1/validate-details-fixture-schema.js",
    "details:shadow:schema:negative": "node tools/details-parity-v1/test-details-fixture-schema-negative.js",
    "details:shadow:fixture:determinism": "node tools/details-parity-v1/test-details-fixture-builder-determinism.js",
    "details:shadow:fixture:coverage": "node tools/details-parity-v1/test-details-fixture-coverage.js",
    "details:shadow:fixture:coverage:negative": "node tools/details-parity-v1/test-details-fixture-coverage-negative.js",
    "details:shadow:suite": "node tools/details-parity-v1/test-native-details-shadow.js",
    "details:shadow:all": "npm run details:shadow:audit && npm run details:shadow:schema && npm run details:shadow:schema:negative && npm run details:shadow:fixture:determinism && npm run details:shadow:fixture:coverage && npm run details:shadow:fixture:coverage:negative && npm run details:shadow:fixture:gaps && npm run details:shadow:suite",
    "details:shadow:fixture:gaps": "node tools/details-parity-v1/audit-details-fixture-gaps.js",
    "details:shadow:all:pssafe": "powershell -NoProfile -ExecutionPolicy Bypass -File tools/details-parity-v1/run-details-shadow-all-powershell-safe.ps1",
    "test:playback-shadow": "python3 tools/playback-parity-v1/run_playback_shadow_ci.py --write-report",
    "report:playback-shadow-pr": "python3 tools/playback-parity-v1/playback_shadow_pr_summary.py --write-report",
    "test:playback-shadow-review": "python3 tools/playback-parity-v1/run_playback_shadow_review_pack.py --write-report",
    "collect:playback-shadow-artifacts": "python3 tools/playback-parity-v1/collect_playback_shadow_artifacts.py",
    "report:playback-shadow-artifacts": "python3 tools/playback-parity-v1/playback_shadow_artifact_manifest.py --write-report",
    "report:playback-shadow-readiness": "python3 tools/playback-parity-v1/playback_shadow_readiness_index.py --write-report",
    "test:playback-shadow-freeze": "python3 tools/playback-parity-v1/playback_shadow_freeze_manifest_gate.py --write-report",
    "details:shadow:summary": "node tools/details-parity-v1/summarize-details-shadow-output.js"
  },
  "dependencies": {
    "axios": "^1.15.0",
    "basic-ftp": "^5.2.2",
    "cheerio": "^1.2.0",
    "express": "^4.18.2"
  },
  "devDependencies": {
    "@types/k6": "^1.7.0"
  }
}
